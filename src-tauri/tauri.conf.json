{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "RedPanda Launcher",
  "version": "0.1.2",
  "identifier": "com.redpanda.launcher",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "RedPanda Launcher",
        "width": 1050,
        "height": 650,
        "decorations": false,
        "transparent": true,
        "resizable": false
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": ["**"]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "fileAssociations": [
      {
        "ext": ["mrpack"],
        "name": "Modrinth Modpack",
        "description": "Modrinth Modpack File",
        "role": "Viewer"
      }
    ],
    "license": "setup/license.txt",
    "windows": {
      "nsis": {
        "installMode": "currentUser",
        "headerImage": "setup/header.bmp",
        "sidebarImage": "setup/sidebar.bmp",
        "displayLanguageSelector": false
      }
    }
  }
}
